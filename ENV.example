DATABASE_URL=postgresql+psycopg://postgres:PASS@127.0.0.1:5432/dance_dev
# SQLAlchemy pool settings per process.
# Example for split services (web + bot): total connections ~= (pool_size + max_overflow) * 2.
DATABASE_POOL_SIZE=3
DATABASE_MAX_OVERFLOW=2
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800
ENV=dev
MIGRATE_ON_START=1
BOOTSTRAP_ON_START=0
SESSION_TTL_DAYS=60
MAX_SESSIONS_PER_USER=5
ROTATE_IF_DAYS_LEFT=7
APP_SECRET_KEY=change-me-strong-secret
BOT_TOKEN=
BOT_USERNAME=dance_studio_admin_bot
WEB_APP_URL=
API_INTERNAL_BASE_URL=http://127.0.0.1:3000
# Optional JSON bootstrap for initial staff seeding.
# Relative paths are resolved from project root.
# Example file: deploy/initial_staff.example.json
INITIAL_STAFF_CONFIG_PATH=
SESSION_PEPPER=change-me-session-pepper
COOKIE_SECURE=0
COOKIE_SAMESITE=Lax
# Explicit allowlist, comma-separated: e.g. https://app.example.com,https://admin.example.com
# Current request host is NOT auto-trusted.
CSRF_TRUSTED_ORIGINS=
# CSP report/enforce switches
CSP_REPORT_ONLY=1
CSP_ENFORCE=0
CSP_REPORT_URI=/csp-report

TG_INIT_DATA_MAX_AGE_SECONDS=600
SESSION_REAUTH_IDLE_SECONDS=86400
BACKUP_ENCRYPTION_REQUIRED=1
# Public age recipient(s) used only for backup encryption (never store AGE-SECRET-KEY in .env)
# BACKUP_AGE_RECIPIENT=age1...
BACKUP_AGE_RECIPIENTS=
# Optional path to age binary (relative to project root or absolute), e.g. scripts/tools/age.exe
BACKUP_AGE_BINARY=
# Optional proxy only for Telegram backup delivery, e.g. socks5://user:pass@host:1080 or http://host:3128
BACKUP_TELEGRAM_PROXY=
# Optional proxy for the main Telegram bot, e.g. socks5://user:pass@host:1080 or http://host:3128
TELEGRAM_PROXY=

VK_MINI_APP_SERVICE_KEY=
VK_MINI_APP_APP_ID=
# Secure key from VK Mini App settings, used to verify launch params sign
VK_MINI_APP_SECRET_KEY=
# Community ID used in VKWebAppAllowMessagesFromGroup. Example: 123456789
VK_COMMUNITY_ID=
# Community token for sending VK messages from community (messages.send).
VK_COMMUNITY_ACCESS_TOKEN=
# VK API version for messages.send.
VK_API_VERSION=5.199
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@example.com
