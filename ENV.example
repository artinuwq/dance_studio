DATABASE_URL=postgresql+psycopg://postgres:PASS@127.0.0.1:5432/dance_dev
# SQLAlchemy pool settings per process.
# Example for split services (web + bot): total connections ~= (pool_size + max_overflow) * 2.
DATABASE_POOL_SIZE=3
DATABASE_MAX_OVERFLOW=2
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800
ENV=dev
MIGRATE_ON_START=1
BOOTSTRAP_ON_START=0
SESSION_TTL_DAYS=60
MAX_SESSIONS_PER_USER=5
ROTATE_IF_DAYS_LEFT=7
APP_SECRET_KEY=change-me-strong-secret
BOT_TOKEN=
BOT_USERNAME=dance_studio_admin_bot
WEB_APP_URL=
API_INTERNAL_BASE_URL=http://127.0.0.1:3000
OWNER_IDS=
TECH_ADMIN_ID=
SESSION_PEPPER=change-me-session-pepper
COOKIE_SECURE=0
COOKIE_SAMESITE=Lax
# Explicit allowlist, comma-separated: e.g. https://app.example.com,https://admin.example.com
# Current request host is NOT auto-trusted.
CSRF_TRUSTED_ORIGINS=

TG_INIT_DATA_MAX_AGE_SECONDS=600
SESSION_REAUTH_IDLE_SECONDS=86400
